# Sidecar HTTP server
PORT=8787
HOST=0.0.0.0

# OpenClaw Gateway WebSocket.
# In production this sidecar is expected to run on the OpenClaw host.
OPENCLAW_GATEWAY_WS_URL=ws://127.0.0.1:18789

# Set one of these to match gateway.auth.mode.
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PASSWORD=
OPENCLAW_DEVICE_IDENTITY_PATH=.openclaw-device.json

# Optional behavior knobs
OPENCLAW_SESSION_PREFIX=voice-web
OPENCLAW_AUDIO_MAX_MB=20
OPENCLAW_REQUEST_TIMEOUT_MS=15000
OPENCLAW_CHAT_TIMEOUT_MS=0
OPENCLAW_HISTORY_LIMIT=80

# Server-side voice processing for car browsers.
OPENCLAW_CLI=openclaw
OPENCLAW_VOICE_TMP_DIR=voice-web-cache
OPENCLAW_VOICE_COMMAND_TIMEOUT_MS=120000
OPENCLAW_TTS_CACHE_TTL_SECONDS=1800
OPENCLAW_TTS_SPEED=1.35
OPENCLAW_STT_LANGUAGE=zh-CN

# STT providers: openclaw, openai-audio, openai-chat-audio, faster-whisper.
OPENCLAW_STT_PROVIDER=faster-whisper
OPENCLAW_STT_MODEL=tiny
OPENCLAW_STT_PROMPT=Transcribe this audio. Return only the transcript.

# OpenAI-compatible STT settings, used by openai-audio/openai-chat-audio.
OPENCLAW_STT_API_BASE_URL=
OPENCLAW_STT_API_KEY=

# Local faster-whisper settings.
OPENCLAW_STT_WHISPER_PYTHON=.venv-whisper/bin/python
OPENCLAW_STT_WHISPER_SCRIPT=scripts/faster_whisper_transcribe.py
OPENCLAW_STT_WHISPER_DEVICE=cpu
OPENCLAW_STT_WHISPER_COMPUTE_TYPE=int8
OPENCLAW_STT_WHISPER_BEAM_SIZE=1

OPENCLAW_TTS_VOICE=
OPENCLAW_TTS_MODEL=

# Browser access password file, relative to the project directory.
OPENCLAW_ACCESS_PASSWORD_FILE=voice-web.password
